{
  "expo": {
    "name": "FinviApp",
    "slug": "finviapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "finviapp",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1800ad"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.finvi.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1800ad",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.finvi.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1800ad"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "finviapp"
      }
    }
  }
}
